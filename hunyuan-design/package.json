{
  "name": "hunyuan-design",
  "version": "5.7.0",
  "private": true,
  "keywords": [
    "monorepo",
    "turbo",
    "hunyuan",
    "hunyuan design",
    "element-plus",
    "vue",
    "vue admin",
    "vue3"
  ],
  "homepage": "https://github.com/hunyuan/hunyuan-design",
  "bugs": "https://github.com/hunyuan/hunyuan-design/issues",
  "repository": "hunyuan/hunyuan-design.git",
  "license": "MIT",
  "author": {
    "name": "hunyuan",
    "email": "admin@hunyuan.com",
    "url": "https://github.com/anncwb"
  },
  "type": "module",
  "scripts": {
    "bootstrap": "pnpm install",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 turbo build",
    "build:analyze": "pnpm -F @hunyuan/web-ele run build:analyze",
    "build:docker": "./scripts/deploy/build-local-docker-image.sh",
    "build:docs": "pnpm run build --filter=@hunyuan/docs",
    "build:app": "pnpm run build --filter=@hunyuan/web-ele",
    "changeset": "pnpm exec changeset",
    "check": "pnpm run check:circular && pnpm run check:dep && pnpm run check:type && pnpm check:cspell",
    "check:circular": "vsh check-circular",
    "check:cspell": "cspell lint \"**/*.ts\" \"**/README.md\" \".changeset/*.md\" --no-progress",
    "check:dep": "vsh check-dep",
    "check:type": "turbo run typecheck",
    "clean": "node ./scripts/clean.mjs",
    "commit": "czg",
    "dev": "pnpm -F @hunyuan/web-ele run dev",
    "dev:docs": "pnpm -F @hunyuan/docs run dev",
    "dev:mock": "pnpm -F @hunyuan/backend-mock run dev",
    "format": "vsh lint --format",
    "lint": "vsh lint",
    "postinstall": "pnpm -r run --if-present stub",
    "preinstall": "npx only-allow pnpm",
    "prepare": "is-ci || pnpm exec lefthook install",
    "preview": "pnpm -F @hunyuan/web-ele run preview",
    "publint": "vsh publint",
    "reinstall": "pnpm run clean -- --del-lock && pnpm install",
    "test:unit": "vitest run --dom",
    "test:e2e": "turbo run test:e2e",
    "update:deps": "npx taze -r -w",
    "version": "pnpm exec changeset version && pnpm install --no-frozen-lockfile",
    "catalog": "pnpm dlx codemod pnpm/catalog"
  },
  "devDependencies": {
    "@changesets/changelog-github": "catalog:",
    "@changesets/cli": "catalog:",
    "@tsdown/css": "catalog:",
    "@types/node": "catalog:",
    "@hunyuan/commitlint-config": "workspace:*",
    "@hunyuan/eslint-config": "workspace:*",
    "@hunyuan/oxfmt-config": "workspace:*",
    "@hunyuan/oxlint-config": "workspace:*",
    "@hunyuan/stylelint-config": "workspace:*",
    "@hunyuan/tailwind-config": "workspace:*",
    "@hunyuan/tsconfig": "workspace:*",
    "@hunyuan/turbo-run": "workspace:*",
    "@hunyuan/vite-config": "workspace:*",
    "@hunyuan/vsh": "workspace:*",
    "@vitejs/plugin-vue": "catalog:",
    "@vitejs/plugin-vue-jsx": "catalog:",
    "cross-env": "catalog:",
    "cspell": "catalog:",
    "eslint": "catalog:",
    "happy-dom": "catalog:",
    "is-ci": "catalog:",
    "lefthook": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "catalog:",
    "rimraf": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:"
  },
  "engines": {
    "node": "^22.18.0 || ^24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.7.0"
}
